aws_region   = "ap-southeast-1"
project_name = "sonns-blog"
environment  = "dev"
owner        = "sonns"
cost_center  = ""

# DNS / TLS
root_domain_name    = "example.com"
site_domain_name    = "dev.example.com"
create_route53_zone = true # dev owns the zone by default; set false here (and true in prod) to flip ownership

# Lambda
lambda_source_dir  = "../../../backend"
lambda_runtime     = "nodejs20.x"
lambda_handler     = "index.handler"
lambda_memory_size = 128
lambda_timeout     = 10

# DynamoDB
dynamodb_billing_mode = "PAY_PER_REQUEST"
dynamodb_hash_key     = "id"

# Secrets Manager
secret_description = "Application API keys/credentials for the Lambda backend (dev)."

# CloudWatch
log_retention_days = 30
alarm_email        = ""

# Only one environment sharing this AWS account/region should manage this.
manage_apigateway_account_settings = true
