aws_region   = "ap-southeast-1"
project_name = "sonns-blogs"
environment  = "dev"
owner        = "sonns"
cost_center  = ""

# DNS / TLS
root_domain_name    = "example.com"
site_domain_name    = "dev.example.com"
create_route53_zone = false # dev owns the zone by default; set false here (and true in prod) to flip ownership

# Lambda - moved to SAM (sam/env/dev.toml). Nothing to configure here anymore.

# DynamoDB
dynamodb_billing_mode = "PAY_PER_REQUEST"

# Secrets Manager
secret_description = "JWT signing secret and other API keys/credentials for the Lambda backend (dev)."

# Only one environment sharing this AWS account/region should manage this.
manage_apigateway_account_settings = true
