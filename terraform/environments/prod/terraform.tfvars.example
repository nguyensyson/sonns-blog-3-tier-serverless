aws_region   = "ap-southeast-1"
project_name = "sonns-blogs"
environment  = "prod"
owner        = "sonns"
cost_center  = ""

# DNS / TLS
root_domain_name    = "example.com"
site_domain_name    = "example.com" # or "www.example.com"
create_route53_zone = false # dev owns the zone by default (see environments/dev); flip if prod should own it instead

# Lambda - 3 independent Python/FastAPI functions + 1 shared layer (see backend/README.md)
lambda_user_source_dir  = "../../../backend/modules/user"
lambda_posts_source_dir = "../../../backend/modules/posts"
lambda_tasks_source_dir = "../../../backend/modules/tasks"
# Either point at the populated layer source dir (run `pip install -r requirements.txt -t python/`
# inside it first) or set lambda_layer_zip_path to a pre-built zip and leave this null.
lambda_layer_source_dir = "../../../backend/layers/common"
# lambda_layer_zip_path = "../../../backend/common-layer.zip"
lambda_runtime      = "python3.12"
lambda_handler      = "main.handler"
lambda_memory_size  = 256
lambda_timeout      = 15
cors_allow_origins  = "https://example.com"

# DynamoDB
dynamodb_billing_mode = "PAY_PER_REQUEST"

# Secrets Manager
secret_description = "JWT signing secret and other API keys/credentials for the Lambda backend (prod)."

# CloudWatch
log_retention_days = 90
alarm_email        = "you@example.com"

# Only one environment sharing this AWS account/region should manage this.
manage_apigateway_account_settings = false
